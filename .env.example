# Copie para .env e preencha os valores
# Em dev local sem SSO, deixe VITE_SSO_ATIVO comentado (ou =false)
# Em produção (server.cjs), defina como =true
VITE_SSO_ATIVO=true

# URL pública da aplicação (sem barra final)
APP_URL=https://pepito.cora.team

# Porta do servidor (default 4173)
PORT=4173

# Google OAuth 2.0 — crie em console.cloud.google.com
# Projeto: Cora (ou crie um novo "pepito-pld")
# Tipo: Web application
# Authorized redirect URIs: https://pepito.cora.team/auth/google/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Segredo para assinar os JWTs de sessão — gere com:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=gere_um_segredo_longo_aqui
